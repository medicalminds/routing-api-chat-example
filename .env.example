# The base URL should include the API prefix if your deployment uses one.
# Example: https://routing.example.com/api
ROUTING_API_BASE_URL=https://your-routing-api.example.com/api

# This key is sent in the start-session request body as organizationKey.
ROUTING_API_KEY=replace-with-your-routing-api-key

# Optional defaults for the session. Leave known facts commented out when you
# want the API to ask for them later only if the routing flow needs them.
ROUTING_TARGET_SYSTEM=symptomscreen
ROUTING_INTERPRETER_MODE=byo
# ROUTING_DATE_OF_BIRTH=1990-01-01
# ROUTING_SEX_ASSIGNED_AT_BIRTH=female
# ROUTING_RELATIONSHIP_TO_PATIENT=self
